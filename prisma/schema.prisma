generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STUDENT
}

enum OutreachStage {
  RESEARCHING
  CONTACTED
  FOLLOWED_UP
  NEGOTIATING
  APPROVED
  REJECTED
  ONBOARDED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  name      String?
  firstName String?
  lastName  String?
  nickname  String?
  companyWebsite String?
  role      Role     @default(STUDENT)
  skoolId   String?  @unique
  // Manually self-reported until a Skool API/webhook integration exists.
  skoolCourseProgressPct Int @default(0)
  // Target monthly recurring revenue, used by the MRR-vs-goal chart.
  monthlyRevenueGoal Decimal? @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  suppliers      Supplier[]
  brands         Brand[]
  products       Product[]
  calculatorRuns CalculatorRun[]
  activities     ActivityLog[]
  tasks          Task[]
  revenueEntries RevenueEntry[]
}

// --- CRM: Wholesale supplier/brand pipeline ---

model Supplier {
  id           String        @id @default(cuid())
  user         User          @relation(fields: [userId], references: [id])
  userId       String
  companyName  String
  contactName  String?
  email        String?
  phone        String?
  website      String?
  stage        OutreachStage @default(RESEARCHING)
  notes        String?
  invoiceTotal Decimal?      @db.Decimal(12, 2)
  archived     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  brands     Brand[]
  followUps  FollowUp[]
}

model Brand {
  id          String        @id @default(cuid())
  user        User          @relation(fields: [userId], references: [id])
  userId      String
  supplier    Supplier?     @relation(fields: [supplierId], references: [id])
  supplierId  String?
  name        String
  category    String?
  stage       OutreachStage @default(RESEARCHING)
  approved    Boolean       @default(false)
  notes       String?
  archived    Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Brand research inputs (manually entered — no live Amazon data feed).
  // Used to compute an opportunity score; see lib/brandScore.ts.
  estimatedMonthlySales Decimal? @db.Decimal(12, 2)
  sellerCount           Int?
  avgPrice              Decimal? @db.Decimal(10, 2)
  reviewCount           Int?

  products Product[]
}

model FollowUp {
  id         String   @id @default(cuid())
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  supplierId String
  dueDate    DateTime
  completed  Boolean  @default(false)
  note       String?
  createdAt  DateTime @default(now())
}

// --- Product research (internal data only, no live Amazon API) ---

model Product {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id])
  userId        String
  brand         Brand?   @relation(fields: [brandId], references: [id])
  brandId       String?
  title         String
  asin          String?
  upc           String?
  cost          Decimal? @db.Decimal(10, 2)
  estimatedSell Decimal? @db.Decimal(10, 2)
  monthlyUnits  Int?
  notes         String?
  launched      Boolean  @default(false)
  archived      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// --- Calculators: store user runs for history/reporting ---

enum CalculatorType {
  ROI
  MARGIN
  BREAK_EVEN
  INVENTORY_COST
  MULTI_PACK
  BUNDLE
  SALES_TAX
  PREP_CENTER
  REORDER
}

model CalculatorRun {
  id        String         @id @default(cuid())
  user      User           @relation(fields: [userId], references: [id])
  userId    String
  type      CalculatorType
  name      String
  inputs    Json
  result    Json
  archived  Boolean        @default(false)
  createdAt DateTime       @default(now())
}

// --- Success tracker: business-progress signals (not video consumption) ---

enum ActivityType {
  SUPPLIER_CONTACTED
  BRAND_APPROVED
  PRODUCT_ANALYZED
  PRODUCT_LAUNCHED
  REVENUE_MILESTONE
  COMMUNITY_ENGAGEMENT
  TASK_COMPLETED
}

model ActivityLog {
  id        String       @id @default(cuid())
  user      User         @relation(fields: [userId], references: [id])
  userId    String
  type      ActivityType
  metadata  Json?
  createdAt DateTime     @default(now())
}

// --- Action-plan checklist (distinct from Skool lesson tasks) ---

model Task {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  title     String
  dueDate   DateTime?
  completed Boolean   @default(false)
  createdAt DateTime  @default(now())
}

// --- Revenue milestones ---

model RevenueEntry {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  amount    Decimal  @db.Decimal(12, 2)
  note      String?
  earnedAt  DateTime @default(now())
  createdAt DateTime @default(now())
}
