generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STUDENT
}

enum OutreachStage {
  RESEARCHING
  CONTACTED
  FOLLOWED_UP
  NEGOTIATING
  APPROVED
  REJECTED
  ONBOARDED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  name      String?
  firstName String?
  lastName  String?
  nickname  String?
  companyWebsite String?
  role      Role     @default(STUDENT)
  skoolId   String?  @unique
  // Manually self-reported until a Skool API/webhook integration exists.
  skoolCourseProgressPct Int @default(0)
  // Target monthly recurring revenue, used by the MRR-vs-goal chart.
  monthlyRevenueGoal Decimal? @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  suppliers          Supplier[]
  brands             Brand[]
  products           Product[]
  calculatorRuns     CalculatorRun[]
  activities         ActivityLog[]
  tasks              Task[]
  revenueEntries     RevenueEntry[]
  pipelines          Pipeline[]
  opportunities      Opportunity[]
  tags               Tag[]
  customFieldFolders CustomFieldFolder[]
  customFields       CustomField[]
  emailTemplates     EmailTemplate[]
}

// --- CRM: Wholesale supplier/brand pipeline ---

model Supplier {
  id           String        @id @default(cuid())
  user         User          @relation(fields: [userId], references: [id])
  userId       String
  companyName  String
  contactName  String?
  email        String?
  phone        String?
  website      String?
  stage        OutreachStage @default(RESEARCHING)
  notes        String?
  invoiceTotal Decimal?      @db.Decimal(12, 2)
  archived     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  brands        Brand[]
  followUps     FollowUp[]
  opportunities Opportunity[]
  tags          ContactTag[]
  fieldValues   ContactFieldValue[]
  contactNotes  ContactNote[]
}

model Brand {
  id          String        @id @default(cuid())
  user        User          @relation(fields: [userId], references: [id])
  userId      String
  supplier    Supplier?     @relation(fields: [supplierId], references: [id])
  supplierId  String?
  name        String
  category    String?
  stage       OutreachStage @default(RESEARCHING)
  approved    Boolean       @default(false)
  notes       String?
  archived    Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Brand research inputs (manually entered — no live Amazon data feed).
  // Used to compute an opportunity score; see lib/brandScore.ts.
  estimatedMonthlySales Decimal? @db.Decimal(12, 2)
  sellerCount           Int?
  avgPrice              Decimal? @db.Decimal(10, 2)
  reviewCount           Int?

  products Product[]
}

model FollowUp {
  id         String   @id @default(cuid())
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  supplierId String
  dueDate    DateTime
  completed  Boolean  @default(false)
  note       String?
  createdAt  DateTime @default(now())
}

// --- Product research (internal data only, no live Amazon API) ---

model Product {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id])
  userId        String
  brand         Brand?   @relation(fields: [brandId], references: [id])
  brandId       String?
  title         String
  asin          String?
  upc           String?
  cost          Decimal? @db.Decimal(10, 2)
  estimatedSell Decimal? @db.Decimal(10, 2)
  monthlyUnits  Int?
  notes         String?
  launched      Boolean  @default(false)
  archived      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// --- Calculators: store user runs for history/reporting ---

enum CalculatorType {
  ROI
  MARGIN
  BREAK_EVEN
  INVENTORY_COST
  MULTI_PACK
  BUNDLE
  SALES_TAX
  PREP_CENTER
  REORDER
}

model CalculatorRun {
  id        String         @id @default(cuid())
  user      User           @relation(fields: [userId], references: [id])
  userId    String
  type      CalculatorType
  name      String
  inputs    Json
  result    Json
  archived  Boolean        @default(false)
  createdAt DateTime       @default(now())
}

// --- Success tracker: business-progress signals (not video consumption) ---

enum ActivityType {
  SUPPLIER_CONTACTED
  BRAND_APPROVED
  PRODUCT_ANALYZED
  PRODUCT_LAUNCHED
  REVENUE_MILESTONE
  COMMUNITY_ENGAGEMENT
  TASK_COMPLETED
}

model ActivityLog {
  id        String       @id @default(cuid())
  user      User         @relation(fields: [userId], references: [id])
  userId    String
  type      ActivityType
  metadata  Json?
  createdAt DateTime     @default(now())
}

// --- Action-plan checklist (distinct from Skool lesson tasks) ---

model Task {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  title     String
  dueDate   DateTime?
  completed Boolean   @default(false)
  createdAt DateTime  @default(now())
}

// --- Revenue milestones ---

model RevenueEntry {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  amount    Decimal  @db.Decimal(12, 2)
  note      String?
  earnedAt  DateTime @default(now())
  createdAt DateTime @default(now())
}

// --- Contact tags ---

model Tag {
  id        String       @id @default(cuid())
  user      User         @relation(fields: [userId], references: [id])
  userId    String
  name      String
  color     String       @default("#3b82f6")
  createdAt DateTime     @default(now())

  contacts  ContactTag[]
}

model ContactTag {
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierId String
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId      String

  @@id([supplierId, tagId])
}

// --- Sales pipelines & opportunities ---

model Pipeline {
  id        String          @id @default(cuid())
  user      User            @relation(fields: [userId], references: [id])
  userId    String
  name      String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  stages        PipelineStage[]
  opportunities Opportunity[]
}

model PipelineStage {
  id         String      @id @default(cuid())
  pipeline   Pipeline    @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  pipelineId String
  name       String
  order      Int         @default(0)
  createdAt  DateTime    @default(now())

  opportunities Opportunity[]
}

model Opportunity {
  id         String         @id @default(cuid())
  user       User           @relation(fields: [userId], references: [id])
  userId     String
  supplier   Supplier?      @relation(fields: [supplierId], references: [id])
  supplierId String?
  pipeline   Pipeline       @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  pipelineId String
  stage      PipelineStage  @relation(fields: [stageId], references: [id], onDelete: Cascade)
  stageId    String
  name       String
  value      Decimal?       @db.Decimal(12, 2)
  status     String         @default("open")
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

// --- Password reset OTP ---

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// --- Contact notes / activity log ---

model ContactNote {
  id         String   @id @default(cuid())
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierId String
  type       String   @default("note")
  content    String
  subject    String?
  createdAt  DateTime @default(now())
}

// --- Email templates ---

model EmailTemplate {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  name      String
  subject   String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Custom fields ---

model CustomFieldFolder {
  id        String        @id @default(cuid())
  user      User          @relation(fields: [userId], references: [id])
  userId    String
  name      String
  order     Int           @default(0)
  createdAt DateTime      @default(now())

  fields    CustomField[]
}

model CustomField {
  id        String             @id @default(cuid())
  user      User               @relation(fields: [userId], references: [id])
  userId    String
  folder    CustomFieldFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  folderId  String?
  name      String
  type      String
  options   Json?
  order     Int                @default(0)
  createdAt DateTime           @default(now())

  values    ContactFieldValue[]
}

model ContactFieldValue {
  id         String      @id @default(cuid())
  field      CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  fieldId    String
  supplier   Supplier    @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierId String
  value      String
  updatedAt  DateTime    @updatedAt

  @@unique([fieldId, supplierId])
}

// --- Access control: only pre-approved emails may register ---

model AllowedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  note      String?  // optional label, e.g. the person's name
  createdAt DateTime @default(now())
}
